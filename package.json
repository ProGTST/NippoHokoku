{
  "name": "nippo-desktop",
  "version": "0.1.12",
  "description": "日報入力デスクトップアプリ（WebView組み込み / Electron）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "dist": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable",
    "publish": "electron-builder --win nsis --publish always"
  },
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "jp.co.genech.nippo.desktop",
    "productName": "日報入力",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/icon.ico"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "日報入力-Setup-${version}.exe",
      "shortcutName": "日報入力"
    },
    "portable": {
      "artifactName": "日報入力-${version}.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "ProGTST",
      "repo": "NippoHokoku"
    },
    "directories": {
      "output": "dist"
    }
  }
}
