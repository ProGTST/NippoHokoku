{
  "name": "nippo-desktop",
  "version": "0.1.0",
  "description": "日報入力デスクトップアプリ（案A: WebView組み込み / Electron）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "dist": "electron-builder --win portable",
    "dist:nsis": "electron-builder --win nsis"
  },
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "jp.co.genech.nippo.desktop",
    "productName": "日報入力",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/icon.ico"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "日報入力-${version}.exe"
    },
    "directories": {
      "output": "dist"
    }
  }
}
